# Sync JokkoNote → Réception élève (serveur dans repo JokkoNote)
REACT_APP_JOKKO_SYNC_URL=http://localhost:8787

# Code PIN pour accès bêta privé (laisser vide en dev local = pas de porte)
REACT_APP_BETA_PIN=

# Backend Python désactivé (stockage local + Google Drive)
REACT_APP_USE_BACKEND=false

# Mode tablette navigateur : pas de code PIN (optionnel)
REACT_APP_KIOSK_MODE=false

# Google Drive — voir GOOGLE_DRIVE.md
# Client OAuth type « Application Web » (origine http://localhost:3000)
REACT_APP_GOOGLE_WEB_CLIENT_ID=
REACT_APP_GOOGLE_TOKEN_URL=
