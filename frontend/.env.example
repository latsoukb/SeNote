# Code PIN pour accès bêta privé (laisser vide en dev local = pas de porte)
REACT_APP_BETA_PIN=

# Backend Python désactivé (stockage local + Google Drive)
REACT_APP_USE_BACKEND=false

# --- APK tablette Android ---
# Mode tablette dédiée : pas de code PIN
REACT_APP_KIOSK_MODE=true

# Google Drive — voir GOOGLE_DRIVE.md (Mac) et ANDROID.md (APK)
# Web : client OAuth type « Application Web » (origine http://localhost:3000)
REACT_APP_GOOGLE_WEB_CLIENT_ID=
# Android : client OAuth type « Android » (package com.senote.tablet)
REACT_APP_GOOGLE_CLIENT_ID=
