# Code PIN pour accès bêta privé (laisser vide en dev local = pas de porte)
REACT_APP_BETA_PIN=

# URL du backend (production)
REACT_APP_API_URL=http://localhost:8000

# --- APK tablette Android ---
# Mode tablette dédiée : pas de code PIN
REACT_APP_KIOSK_MODE=true

# Google Drive (OAuth Android — voir ANDROID.md)
REACT_APP_GOOGLE_CLIENT_ID=
REACT_APP_GOOGLE_WEB_CLIENT_ID=
